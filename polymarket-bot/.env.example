# Polymarket CLOB API credentials
# Your Ethereum/Polygon private key (keep this secret!)
PRIVATE_KEY=0xyour_private_key_here

# Polymarket API host
POLYMARKET_HOST=https://clob.polymarket.com

# Chain ID: 137 = Polygon mainnet, 80002 = Amoy testnet
CHAIN_ID=137

# Optional: Funder address if using a proxy wallet
# FUNDER_ADDRESS=0x...

# Trading parameters
MAX_POSITION_USDC=50         # Max USDC per position
MAX_OPEN_POSITIONS=5         # Max concurrent open positions
MIN_LIQUIDITY_USDC=500       # Min market liquidity to trade
MIN_EDGE=0.02                # Min edge (2%) required to enter a trade
KELLY_FRACTION=0.25          # Fraction of Kelly criterion to use (0.25 = quarter Kelly)

# Strategy settings
STRATEGY=value               # Options: value, momentum, random
SCAN_INTERVAL_SECONDS=60     # How often to scan for opportunities

# Dry run mode: set to true to simulate without placing real orders
DRY_RUN=true
